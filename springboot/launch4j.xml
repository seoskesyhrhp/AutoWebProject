  <downloadUrl>https://adoptium.net/</downloadUrl>
  <supportUrl>https://adoptium.net/</supportUrl>
  <stayAlive>false</stayAlive>
  <restartOnCrash>false</restartOnCrash>
  <versionInfo>
    <fileVersion>1.0.1.0</fileVersion>
    <txtFileVersion>1.0.1</txtFileVersion>
    <fileDescription>AutoWeb Spring Boot Service</fileDescription>
    <copyright>SmartChat</copyright>
    <productVersion>1.0.1.0</productVersion>
    <txtProductVersion>1.0.1</txtProductVersion>
    <productName>AutoWeb Spring Boot</productName>
    <companyName>SmartChat</companyName>
    <internalName>autoweb-springboot</internalName>
    <originalFilename>autoweb-springboot.exe</originalFilename>
  </versionInfo>
  <jre>
    <path>jre</path>
    <minVersion>17</minVersion>
    <jdkPreference>preferJre</jdkPreference>
    <runtimeBits>64/32</runtimeBits>
  </jre>
