<launch4jConfig>
  <dontWrapJar>false</dontWrapJar>
  <headerType>gui</headerType>
  <jar>target/autoweb-springboot-1.0.1.jar</jar>
  <outfile>autoweb-springboot.exe</outfile>
  <icon>icon.ico</icon>
  <errTitle>AutoWeb Spring Boot</errTitle>
  <cmdLine>--spring.profiles.active=prod --server.port=8000</cmdLine>
